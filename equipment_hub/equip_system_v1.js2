  // ==== 部位定義（集中管理：新增裝備只要在 DEF_BASE/DEF_SLOTS/DEF_NAME 追加即可）====
  const DEF_NAME = {
    // 防具
    hat:'帽子', suit:'套服', glove:'手套', cape:'披風', shoes:'鞋子', shoulder:'肩膀',

    // 武器類
