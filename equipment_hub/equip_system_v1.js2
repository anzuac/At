    suit: { N:'制式皮甲', R:'獵人皮甲', SR:'風紋戰衣', SSR:'王獵戰衣', UR:'逐風戰衣', LR:'古獵星衣', SLR:'終局獵王衣' },
    glove: { N:'制式手套', R:'射手手套', SR:'風紋護手', SSR:'王獵護手', UR:'逐風護手', LR:'古獵護手', SLR:'終局獵王護手' },
    weapon: { N:'訓練弓', R:'強弦長弓', SR:'風切戰弓', SSR:'王獵裁定弓', UR:'英雄逐風之弓', LR:'世界貫穿弓', SLR:'終焉定軌神弓' },
